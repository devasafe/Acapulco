# ===== Backend (Render) =====

# Banco de dados (MongoDB Atlas)
MONGO_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/acapulco?retryWrites=true&w=majority

# Segredo para assinar os tokens JWT (use uma string aleatória longa)
JWT_SECRET=troque-por-uma-string-aleatoria-bem-longa

# Porta — o Render injeta automaticamente; pode deixar em branco
PORT=5000

# CORS: URL(s) do frontend permitidas (separe por vírgula). Ex.: https://acapulco.vercel.app
# Se ficar em branco, libera qualquer origem (útil só em demo).
CORS_ORIGIN=

# URL do frontend (usada em links/referral) — opcional
FRONTEND_URL=
